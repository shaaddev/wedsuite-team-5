{
	"name": "@websuite/backend",
	"version": "0.0.0",
	"private": true,
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./onboarding": {
			"types": "./src/onboarding.ts",
			"default": "./src/onboarding.ts"
		}
	},
	"scripts": {
		"check": "ultracite check",
		"format": "ultracite fix",
		"format:unsafe": "ultracite fix --unsafe",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@websuite/typescript-config": "workspace:*"
	}
}
