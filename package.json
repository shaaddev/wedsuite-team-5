{
  "name": "websuite",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "web:dev": "cd apps/web && bun run dev",
    "web:build": "cd apps/web && bun run build",
    "mobile:dev": "cd apps/mobile && bun run dev",
    "build": "turbo build",
    "check": "turbo check",
    "format": "turbo format",
    "format:unsafe": "turbo format:unsafe",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "turbo": "^2.8.8",
    "typescript": "^5",
    "ultracite": "7.2.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "date-fns": "^4.1.0"
  }
}
