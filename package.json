{
  "name": "websuite",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "web:dev": "cd apps/web && bun run dev",
    "web:check": "cd apps/web && bun run check",
    "web:format": "cd apps/web && bun run format",
    "web:format:unsafe": "cd apps/web && bun run format:unsafe",
    "web:build": "cd apps/web && bun run build",
    "mobile:dev": "cd apps/mobile && bun run dev",
    "build": "turbo build",
    "check": "turbo check",
    "format": "turbo format",
    "format:unsafe": "turbo format:unsafe",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun x tsx db/migrate.ts",
    "db:migrate:prod": "NODE_ENV=production bun x tsx db/migrate.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "drizzle-kit": "^0.31.9",
    "turbo": "^2.8.8",
    "typescript": "^5",
    "ultracite": "7.2.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "better-auth": "^1.5.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "expo-secure-store": "^15.0.8",
    "postgres": "^3.4.8"
  }
}
