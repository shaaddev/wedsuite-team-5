{
	"expo": {
		"name": "websuite-mobile",
		"slug": "websuite-mobile",
		"version": "1.0.0",
		"orientation": "portrait",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"scheme": "websuite",
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.websuite.mobile"
		},
		"android": {
			"package": "com.websuite.mobile"
		},
		"web": {
			"bundler": "metro"
		},
		"plugins": ["expo-router"]
	}
}
